# Copy this file to .env.local and fill in your Supabase project values.
# In Vercel, set these under Project Settings → Environment Variables (Production).
#
# Find these values at: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

